# Swell Quant local configuration.
# Never commit real API keys or local secrets.

DATA_DIR=./data
DUCKDB_PATH=./data/duckdb/swell_quant.duckdb

DATA_SOURCE=sample
# manual uses AKSHARE_SYMBOLS; csi800/hs300_csi500 fetch HS300 + CSI500 constituents at runtime.
AKSHARE_UNIVERSE_MODE=manual
AKSHARE_SYMBOLS=000001.SZ,000002.SZ,600000.SH
AKSHARE_START_DATE=20240101
AKSHARE_END_DATE=20240229
AKSHARE_BENCHMARK_SYMBOL=sh000906
AKSHARE_MAX_SYMBOLS=

MODEL_TYPE=lightgbm

LLM_PROVIDER=disabled
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
